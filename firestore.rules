rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Basic authentication function
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check if the user is accessing their own data
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users Collection
    // Users can read and write their own profile
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Trips Collection
    match /trips/{tripId} {
      // Allow read if the user is the owner OR if the trip is public
      allow read: if isOwner(resource.data.userId) || resource.data.isPublic == true;
      // Allow create if authenticated and setting themselves as the owner
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // Allow update/delete if the user is the owner
      allow update, delete: if isOwner(resource.data.userId);
      
      // Stops subcollection inside trips
      match /stops/{stopId} {
        // Access rules cascade or need to check parent document owner
        allow read: if get(/databases/$(database)/documents/trips/$(tripId)).data.userId == request.auth.uid || get(/databases/$(database)/documents/trips/$(tripId)).data.isPublic == true;
        allow write: if get(/databases/$(database)/documents/trips/$(tripId)).data.userId == request.auth.uid;
      }
    }

    // Cities Collection (Read-only for users, managed by admins)
    match /cities/{cityId} {
      allow read: if isAuthenticated();
      allow write: if false; // Assuming only admins can add cities
    }

    // Activities Collection (Read-only for users, managed by admins)
    match /activities/{activityId} {
      allow read: if isAuthenticated();
      allow write: if false; // Assuming only admins can add global activities
    }

    // PackingLists Collection
    match /packingLists/{tripId} {
      // Check parent trip owner
      allow read: if get(/databases/$(database)/documents/trips/$(tripId)).data.userId == request.auth.uid || get(/databases/$(database)/documents/trips/$(tripId)).data.isPublic == true;
      allow write: if get(/databases/$(database)/documents/trips/$(tripId)).data.userId == request.auth.uid;
    }

    // SharedTrips Collection
    match /sharedTrips/{shareId} {
      allow read: if true; // Public access for shared links
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isOwner(resource.data.userId);
    }
  }
}
